# PostgreSQL URL used by the application at runtime. In production, use the
# Supabase transaction pooler (port 6543, commonly with `pgbouncer=true`).
# Do not commit real credentials or production URLs.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/flow_cafe?schema=public"

# PostgreSQL URL used only by Prisma CLI schema operations (`db push`,
# migrations and introspection). With Supabase, use the direct connection or
# session pooler (port 5432), without `pgbouncer=true`.
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/flow_cafe?schema=public"

# Idempotent local seed. Use fictitious local credentials only.
SEED_OWNER_EMAIL="owner@flowcafe.local"
SEED_OWNER_PASSWORD="FlowCafe@123"

# Optional HTTP endpoint for the local print agent.
# Leave empty to disable webhook delivery in local development.
PRINT_WEBHOOK_URL=""
